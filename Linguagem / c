#include <stdio.h>

int main() {
    int i, n;

    // Números pares de 1 a 20
    printf("Numeros pares de 1 a 20:\n");
    for (i = 1; i <= 20; i++) {
        if (i % 2 == 0) {
            printf("%d ", i);
        }
    }

    // Tabuada
    printf("\n\nDigite um numero para ver a tabuada: ");
    scanf("%d", &n);

    printf("\nTabuada do %d:\n", n);
    for (i = 1; i <= 10; i++) {
        printf("%d x %d = %d\n", n, i, n * i);
    }

    return 0;
}
