#include <stdio.h>
#define MAX 10

typedef struct {
    int dados[MAX];
    int topo;
} Pilha;

void inicializar(Pilha *p) {
    p->topo = -1;
}

int estaVazia(Pilha *p) {
    return p->topo == -1;
}

void push(Pilha *p, int valor) {
    p->dados[++p->topo] = valor;
}

int pop(Pilha *p) {
    return p->dados[p->topo--];
}

int main() {

    Pilha p;
    inicializar(&p);

    int v[] = {1, 2, 3, 4, 5, 6};

    int tamanho = 6;

    printf("vetor original: \n");

    for(int i = 0; i < tamanho; i++) {
        printf("%d ", v[i]);
        push(&p, v[i]);
    }

    for(int i = 0; i < tamanho; i++) {
        v[i] = pop(&p);
    }

    printf("\n\nvetor invertido:\n");

    for(int i = 0; i < tamanho; i++) {
        printf("%d ", v[i]);
    }

    return 0;
}
