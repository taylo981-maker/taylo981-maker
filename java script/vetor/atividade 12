let estoque = [10, 0 , 5, 1, 15, 2, 8];
let contardeestoque = 0;
let estoquebaixo = 0;
let reposiçaodeestoque = 0;

for (let i = 0; i < estoque.length; i++){
    let quantidade = estoque[i];

    if (quantidade === 0){
        contardeestoque++;
    contardeestoque++;
    } else if (quantidade < 5){
        estoquebaixo++;
    reposiçaodeestoque++;
    } 
}

console.log("Produtos sem estoque: " + contardeestoque);
console.log("Produtos com estoque baixo: " + estoquebaixo);
console.log("Produtos que precisam de reposição: " + reposiçaodeestoque);
