const prompt = require('prompt-sync')();
let nomes = [];

for (let i = 0; i < 5; i++) {
    let nome = prompt("nomes " + (i + 1) + ": ");
    nomes.push(nome);
}

for (let i = 0; i < nomes.length; i++) {
    console.log("Bem Vindo Programador, " + nomes[i] + "!");
}

console.log("\nTotal de pessoas: " + nomes.length);
