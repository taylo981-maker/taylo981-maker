let soma = 0;

let matriz = [
    [9, 5, 10],
    [7, 9, 7],
    [4, 6, 8]
];

for (let i = 0; i < matriz.length; i++) {
    console.log("aluno " + i + ":");

    let somaNotas = 0;
    for (let j = 0; j < matriz[i].length; j++) {
        console.log("disciplina " + j + ": " + matriz[i][j]);
        somaNotas += matriz[i][j];
    }

    let media = somaNotas / matriz[i].length;
    soma += media;
}

console.log("soma das médias: " + soma);
